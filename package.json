{
  "name": "baseedwork",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @baseedwork/db migrate",
    "db:generate": "pnpm --filter @baseedwork/db generate",
    "db:seed": "pnpm --filter @baseedwork/db seed",
    "db:studio": "pnpm --filter @baseedwork/db studio",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@swc/core",
      "esbuild"
    ]
  }
}